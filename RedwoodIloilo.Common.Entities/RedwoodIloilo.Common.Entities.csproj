<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet Package Metadata -->
    <PackageId>RedwoodIloilo.Common.Entities</PackageId>
    <Version>1.0.10</Version>
    <Authors>Emmanuel</Authors>
    <Company>Redwood Iloilo</Company>
    <Description>Redwood Iloilo Common Entities</Description>
    <PackageTags>utility;shared;common</PackageTags>
    <RepositoryUrl>https://github.com/ejbaling/redwoodiloilo-common-entities</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/ejbaling/redwoodiloilo-common-entities</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>

    <!-- Optional: automatically create package on build -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>

    <!-- Allow SDK to generate assembly attributes to avoid duplicate definitions -->
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

  <PropertyGroup>
    <AssemblyVersion>1.0.10.0</AssemblyVersion>
    <FileVersion>1.0.10.0</FileVersion>
    <AssemblyInformationalVersion>1.0.10</AssemblyInformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Pgvector" Version="0.3.2" />
  </ItemGroup>

</Project>
